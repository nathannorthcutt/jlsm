<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.0//EN"
    "https://checkstyle.org/dtds/suppressions_1_0.dtd">
<suppressions>
    <!--
      Test files use underscored method names (e.g. givenX_whenY_thenZ) and
      static star imports from JUnit/AssertJ — both are idiomatic in tests.
    -->
    <suppress checks="MethodName"      files="Test\.java$"/>
    <suppress checks="AvoidStarImport" files="Test\.java$"/>
    <!--
      Some test files organize nested @Nested classes into underscored domain groups
      (e.g. "Structural_Chokepoint") to match spec requirement clusters. This naming
      is an intentional test-only idiom.
    -->
    <suppress checks="TypeName"        files="Test\.java$"/>
    <!--
      FieldType.boolean_() uses a trailing underscore to avoid collision with the
      Java keyword 'boolean'. This is an intentional API design choice.
    -->
    <suppress checks="MethodName" files="FieldType\.java$"/>
</suppressions>
