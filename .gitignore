# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
*.iml
.vscode/
.project
.classpath
.settings/
bin/

# OS
.DS_Store
Thumbs.db

# Claude Code — local-only settings (user-specific permission grants)
.claude/settings.local.json
.claude/worktrees/

# Feature working state — scratch directories, not source-controlled
# project-config.md and CLAUDE.md are committed (see below)
.feature/*/
.feature/_archive/

# Explicitly track the project config and index
!.feature/project-config.md
!.feature/CLAUDE.md

# Performance analysis — scratch and transient output
perf-scratch/
perf-output/**/*.collapsed
perf-output/**/*.jfr
perf-output/**/results.json
perf-output/**/*-results.json
perf-output/**/run-manifest.json
perf-output/**/latest-*
perf-output/**/gc.log
!perf-output/findings.md

# vallorcine runtime files — generated at runtime, not committed
.claude/.statusline-baseline
.claude/.token-state
.claude/.token-checkpoint
.feature/
.curate/
