{
  "permissions": {
    "allow": [
      "Bash(./gradlew:*)",
      "Bash(git:*)",
      "mcp__ide__getDiagnostics"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat > /dev/null; bash .claude/scripts/dashboard-stop-hook.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/token-stop-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/scripts/statusline.sh"
  }
}
